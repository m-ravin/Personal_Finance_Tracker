# Personal Finance Tracker — environment variables
# Copy to .env and fill in values. All keys are optional.
# Without any key, categorisation falls back to keyword + fuzzy matching only.

# ── LLM Categorisation (optional) ────────────────────────────────────────────
# Set one of the following to enable AI-powered transaction categorisation.
# Configure the active provider in the app: Settings → LLM Configuration.

ANTHROPIC_API_KEY=sk-ant-...        # Claude (claude-sonnet-4-20250514)
OPENAI_API_KEY=sk-...               # GPT-4o-mini
GROQ_API_KEY=gsk_...                # Llama3-70b (free tier available)
